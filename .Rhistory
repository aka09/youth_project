geom_smooth() +
facet_wrap(~type) +
labs(x = "Age",
y = "Proportion not satisfied at all (0)",
caption = "Point transparency represents n") +
scale_x_continuous(breaks = seq(20, 90, 10)) +
scale_y_continuous(breaks = seq(0, .1, .02)) +
theme_bw(base_family = "Fira Sans")
library(tidyverse)
library(haven)
library(magrittr)
library(ggplot2)
library(extrafont)
library(DescTools)
source("functions/confint.R")
# Data from 9th ESS wave
ess9.orig <- read_dta("ess/data/ess_wave6.dta")
# Data from 9th ESS wave
ess6.orig <- read_dta("ess/data/ess_wave6.dta")
rm(ess9.orig)
View(ess6.orig)
View(ess6.orig)
ess6.orig$agea %>% table()
# Renaming columns
ess9 <-
rename(ess9.orig,
dem.satisfied = stfdem,
dem.important = implvdm,
age = agea)
# Renaming columns
ess6 <-
rename(ess6.orig,
dem.satisfied = stfdem,
dem.important = implvdm,
age = agea)
table(ess6$dem.satisfied)
table(ess6$dem.important)
cor(ess6$dem.important, ess6$dem.satisfied, use = "complete.obs")
# Recoding
ess6 %<>%
mutate(
generation = case_when(
age >= 18 & age < 25 ~ "18-24",
age >= 25 & age < 35 ~ "25-34",
age >= 35 & age < 45 ~ "35-44",
age >= 45 & age < 54 ~ "45-54",
age >= 55 & age < 65 ~ "55-64",
age >= 65 ~ "65+",
)
)
table(ess6$generation, useNA = "always")
ess6 %>%
group_by(generation) %>%
cor(dem.important, dem.satisfied)
ess6 %>%
group_by(generation) %>%
cor(.$dem.important, .$dem.satisfied)
ess6 %>%
group_by(generation) %>%
summarize(cor = cor(dem.important, dem.satisfied))
ess6 %>%
filter(!is.na(generation)) %>%
group_by(generation) %>%
summarize(cor = cor(dem.important, dem.satisfied,
use = "complete.obs"))
# Mean importance by age (with loess)
ess9 %>%
group_by(age) %>%
summarise(mean.important = weighted.mean(dem.important,
na.rm = T,
w = anweight),
lwr = lwr_conf(dem.important),
upr = upr_conf(dem.important),
`Sample size` = n()) %>%
ggplot(aes(x = age, y = mean.important, weight = `Sample size`)) +
geom_point(aes(size = `Sample size`), alpha = 0.2) +
geom_smooth(se = FALSE) +
labs(x = "Age",
y = "Importance of democracy (0-10)",
caption = "Loess line weighted by sample size") +
scale_x_continuous(breaks = seq(15, 90, 5)) +
theme_bw(base_family = "Fira Sans")
